<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ProfileActivity"
    android:orientation="vertical"
    android:background="@drawable/edbackground_img1">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/txt_profile"
            android:layout_width="338dp"
            android:layout_height="62dp"
            android:layout_marginStart="33dp"
            android:layout_marginTop="40dp"
            android:layout_marginEnd="33dp"
            android:layout_marginBottom="33dp"
            android:gravity="center"
            android:text="Profile"
            android:textColor="@color/white"
            android:textSize="35sp" />

        <EditText
            android:id="@+id/etxt_name"
            android:layout_width="338dp"
            android:layout_height="70dp"
            android:layout_below="@id/txt_profile"
            android:layout_marginStart="33dp"
            android:layout_marginTop="25dp"
            android:layout_marginEnd="33dp"
            android:layout_marginBottom="5dp"
            android:background="@drawable/white_border"
            android:color="@color/white"
            android:drawableStart="@drawable/ic_baseline_person1_24"
            android:drawablePadding="8dp"
            android:gravity="center"
            android:hint="Enter Name*"
            android:padding="20dp"
            android:textColor="@color/white"
            android:textColorHighlight="@color/cardview_dark_background"
            android:textColorHint="@color/grey_1"
            android:textSize="15sp" />

        <EditText
            android:id="@+id/etxt_phone_no"
            android:layout_width="338dp"
            android:layout_height="70dp"
            android:layout_below="@id/etxt_name"
            android:layout_marginStart="33dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="33dp"
            android:layout_marginBottom="5dp"
            android:background="@drawable/white_border"
            android:color="@color/white"
            android:drawableLeft="@drawable/ic_baseline_phone1_android_24"
            android:drawablePadding="8dp"
            android:gravity="center"
            android:inputType="number"
            android:hint="Enter Phone number*"
            android:padding="20dp"
            android:textColor="@color/white"
            android:textColorHighlight="@color/cardview_dark_background"
            android:textColorHint="@color/grey_1"
            android:textSize="15sp" />

        <EditText
            android:id="@+id/etxt_email"
            android:layout_width="338dp"
            android:layout_height="70dp"
            android:layout_below="@id/etxt_phone_no"
            android:layout_marginStart="33dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="33dp"
            android:layout_marginBottom="5dp"
            android:background="@drawable/white_border"
            android:color="@color/white"
            android:drawableLeft="@drawable/ic_baseline_email1_24"
            android:drawablePadding="8dp"
            android:gravity="center"
            android:hint="Enter e-mail"
            android:padding="20dp"
            android:textColor="@color/white"
            android:textColorHighlight="@color/cardview_dark_background"
            android:textColorHint="@color/grey_1"
            android:textSize="15sp" />

        <EditText
            android:id="@+id/etxt_company_name"
            android:layout_width="338dp"
            android:layout_height="70dp"
            android:layout_below="@id/etxt_email"
            android:layout_marginStart="33dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="33dp"
            android:layout_marginBottom="5dp"
            android:background="@drawable/white_border"
            android:color="@color/white"
            android:drawableLeft="@drawable/ic_baseline_business1_24"
            android:drawablePadding="8dp"
            android:gravity="center"
            android:hint="Enter Company name"
            android:padding="20dp"
            android:textColor="@color/white"
            android:textColorHighlight="@color/cardview_dark_background"
            android:textColorHint="@color/grey_1"
            android:textSize="15sp" />

        <EditText
            android:id="@+id/etxt_job_title"
            android:layout_width="338dp"
            android:layout_height="70dp"
            android:layout_below="@id/etxt_company_name"
            android:layout_marginStart="33dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="33dp"
            android:layout_marginBottom="5dp"
            android:background="@drawable/white_border"
            android:color="@color/white"
            android:drawableLeft="@drawable/ic_baseline_id1_24"
            android:drawablePadding="8dp"
            android:gravity="center"
            android:hint="Enter Job title"
            android:padding="20dp"
            android:textColor="@color/white"
            android:textColorHighlight="@color/cardview_dark_background"
            android:textColorHint="@color/grey_1"
            android:textSize="15sp" />

        <EditText
            android:id="@+id/etxt_address"
            android:layout_width="338dp"
            android:layout_height="70dp"
            android:layout_below="@id/etxt_job_title"
            android:layout_marginStart="33dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="33dp"
            android:layout_marginBottom="5dp"
            android:background="@drawable/white_border"
            android:color="@color/white"
            android:drawableLeft="@drawable/ic_baseline_home1_work_24"
            android:drawablePadding="8dp"
            android:gravity="center"
            android:hint="Enter address"
            android:padding="20dp"
            android:textColor="@color/white"
            android:textColorHighlight="@color/cardview_dark_background"
            android:textColorHint="@color/grey_1"
            android:textSize="15sp" />


        <!-- generate button-->
        <Button
            android:id="@+id/btn_create"
            android:layout_width="299dp"
            android:layout_height="75dp"
            android:layout_below="@id/etxt_address"
            android:layout_alignParentStart="true"
            android:layout_alignParentEnd="true"
            android:layout_marginStart="31dp"
            android:layout_marginTop="40dp"
            android:layout_marginEnd="34dp"
            android:layout_marginBottom="5dp"
            android:backgroundTint="@color/purple"
            android:text="@string/generate"
            android:textSize="20sp"
            android:textStyle="bold"
            app:cornerRadius="30dp" />

        <ImageView
            android:id="@+id/img_gen_qr_code"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/btn_create"
            android:layout_marginTop="25dp"
            android:layout_marginBottom="5dp"/>

<!-- Button to share the QR code  -->
        <ImageButton
            android:id="@+id/btn_share"
            style="@style/Widget.AppCompat.ImageButton"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_below="@id/img_gen_qr_code"
            android:layout_alignParentStart="true"
            android:layout_marginStart="75dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/round_btn"
            android:src="@drawable/ic_baseline_share1_24"
            app:cornerRadius="50dp" />


        <!-- Button to dwld QR code-->
        <ImageButton
            android:id="@+id/btn_download"
            style="@style/Widget.AppCompat.ImageButton"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_below="@id/img_gen_qr_code"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="75dp"
            android:background="@drawable/round_btn"
            android:src="@drawable/ic_baseline_download1_24"
            app:cornerRadius="50dp"/>



        <!-- Button to web search QR code -->
        <ImageButton
            android:id="@+id/btn_web_search"
            style="@style/Widget.AppCompat.ImageButton"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_below="@id/btn_share"
            android:layout_alignParentStart="true"
            android:layout_marginStart="75dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="15dp"
            android:background="@drawable/round_btn"
            android:src="@drawable/ic_baseline_websearch1_24"
            app:cornerRadius="50dp" />

        <!-- Button to add the qr code to favorite-->
        <ImageButton
            android:id="@+id/btn_favorite"
            style="@style/Widget.AppCompat.ImageButton"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_below="@id/btn_download"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="75dp"
            android:layout_marginBottom="15dp"
            android:background="@drawable/round_btn"
            android:src="@drawable/ic_baseline_favorite1_24"
            app:cornerRadius="50dp" />

    </RelativeLayout>

</ScrollView>