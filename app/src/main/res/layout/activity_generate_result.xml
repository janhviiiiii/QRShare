<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Generate_Result"
    android:background="@drawable/edbackground_img1">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">


        <TextView
            android:id="@+id/txt_heading1"
            android:layout_width="400dp"
            android:layout_height="90dp"
            android:layout_marginStart="30dp"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="30dp"
            android:gravity="center"
            android:text="Generated QR Code"
            android:textColor="@color/white"
            android:textSize="25sp" />


        <ImageView
            android:id="@+id/img_gen_qr_code"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/txt_heading1"
            android:layout_marginTop="15dp" />
        <!--            android:src="@drawable/ic_baseline_android1_24" -->




        <ImageButton
            android:id="@+id/btn_download"
            style="@style/Widget.AppCompat.ImageButton"
            android:layout_width="90dp"
            android:layout_height="64dp"
            android:layout_below="@id/img_gen_qr_code"
            android:layout_alignParentStart="true"
            android:layout_alignParentEnd="true"
            android:layout_marginStart="150dp"
            android:layout_marginTop="13dp"
            android:layout_marginEnd="150dp"
            android:background="@color/purple"
            android:src="@drawable/ic_baseline_download1_24"
            app:cornerRadius="50dp"
            tools:ignore="SpeakableTextPresentCheck" />


    </RelativeLayout>



</ScrollView>