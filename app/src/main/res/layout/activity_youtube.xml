<?xml version="1.0" encoding="utf-8"?>
<ScrollView
xmlns:android="http://schemas.android.com/apk/res/android"
xmlns:app="http://schemas.android.com/apk/res-auto"
xmlns:tools="http://schemas.android.com/tools"
android:layout_width="match_parent"
android:layout_height="match_parent"
android:background="@drawable/edbackground_img1"
tools:context=".YoutubeActivity">


<RelativeLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <TextView
        android:id="@+id/txt_youtube"
        android:layout_width="338dp"
        android:layout_height="62dp"
        android:layout_marginStart="33dp"
        android:layout_marginTop="40dp"
        android:layout_marginEnd="33dp"
        android:layout_marginBottom="33dp"
        android:gravity="center"
        android:text="Youtube"
        android:textColor="@color/white"
        android:textSize="35sp" />


    <ImageView
        android:id="@+id/img_youtube"
        android:layout_width="82dp"
        android:layout_height="50dp"
        android:layout_below="@id/txt_youtube"
        android:layout_marginStart="168dp"
        android:layout_marginTop="25dp"
        android:layout_marginEnd="168dp"
        android:layout_marginBottom="5dp"
        app:srcCompat="@drawable/youtube_1">

    </ImageView>

    <!--    layout for the username, link tab-->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/img_youtube"
        android:layout_marginStart="33dp"
        android:layout_marginTop="25dp"
        android:layout_marginEnd="33dp"
        android:layout_marginBottom="5dp" />

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/view_pager"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="33dp"
        android:layout_marginTop="70dp"
        android:layout_marginEnd="33dp"
        android:layout_marginBottom="0dp" />

</RelativeLayout>

</ScrollView>
